{
	"name": "inbox-angel-worker",
	"version": "0.7.0",
	"private": true,
	"scripts": {
		"deploy": "npm run build:dashboard && wrangler deploy",
		"migrate": "wrangler d1 migrations apply DB --remote",
		"dev": "wrangler dev",
		"dev:dashboard": "npm --prefix dashboard run dev",
		"build:dashboard": "npm --prefix dashboard run build",
		"start": "wrangler dev",
		"test": "vitest --config vitest.node.config.mts",
		"test:workers": "vitest --config vitest.config.mts",
		"cf-typegen": "wrangler types",
		"seed:local": "npx tsx scripts/seed-demo.ts > /tmp/ia-seed.sql && wrangler d1 execute inbox-angel --local  --file=/tmp/ia-seed.sql; rm -f /tmp/ia-seed.sql",
		"seed:remote": "npx tsx scripts/seed-demo.ts > /tmp/ia-seed.sql && wrangler d1 execute inbox-angel --remote --file=/tmp/ia-seed.sql; rm -f /tmp/ia-seed.sql",
		"unseed:local": "wrangler d1 execute inbox-angel --local  --file=scripts/unseed-demo.sql",
		"unseed:remote": "wrangler d1 execute inbox-angel --remote --file=scripts/unseed-demo.sql"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@cloudflare/workers-types": "^4.20260307.1",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.71.0"
	},
	"dependencies": {
		"fast-xml-parser": "^5.4.2",
		"fflate": "^0.8.2"
	}
}